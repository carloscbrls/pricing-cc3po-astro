---
const navLinks = [
	{ href: 'https://cc3po.com', label: 'Home' },
	{ href: 'https://offers.cc3po.com', label: 'Services' },
	{ href: 'https://docs.cc3po.com', label: 'Docs' },
	{ href: 'https://insights.cc3po.com', label: 'Blog' },
];
---

<header class="header">
	<div class="header-inner">
		<a href="/" class="logo">
			<img src="https://cc3po.com/wp-content/uploads/2023/02/White-logo-no-background-scaled.png" alt="CC3PO" style="height: 45px; width: auto;" />
		</a>
		<nav class="nav">
			{navLinks.map(link => (
				<a href={link.href}>{link.label}</a>
			))}
			<a href="https://offers.cc3po.com/contact" class="nav-cta">Get Started</a>
		</nav>
	</div>
	<button class="mobile-toggle" id="nav-toggle" aria-label="Menu">
		<span></span>
		<span></span>
		<span></span>
	</button>
</header>

<div class="mobile-menu" id="mobile-menu">
	{navLinks.map(link => (
		<a href={link.href}>{link.label}</a>
	))}
	<a href="https://offers.cc3po.com/contact" style="background: linear-gradient(135deg, #6b35ff, #00d2ff); color: #fff; text-align: center; border-radius: 8px; margin-top: 12px; padding: 14px;">Get Started</a>
</div>

<style>
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(10, 10, 11, 0.9);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 16px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		font-size: 18px;
	}
	.logo img {
		height: 45px;
		width: auto;
	}
	.nav {
		display: flex;
		align-items: center;
		gap: 32px;
	}
	.nav a {
		color: #a1a1aa;
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		transition: color 0.2s;
	}
	.nav a:hover {
		color: #fff;
	}
	.nav-cta {
		padding: 10px 20px;
		background: linear-gradient(135deg, #6b35ff, #00d2ff);
		color: #fff !important;
		border-radius: 24px;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.nav-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 15px rgba(107, 53, 255, 0.4);
	}
	.mobile-toggle {
		display: none;
		flex-direction: column;
		justify-content: space-between;
		width: 28px;
		height: 20px;
		cursor: pointer;
		padding: 4px;
		margin-left: 16px;
		background: transparent;
		border: none;
	}
	.mobile-toggle span {
		display: block;
		width: 100%;
		height: 2px;
		background: #fff;
		transition: all 0.3s;
		transform-origin: center;
	}
	.mobile-toggle.active span:nth-child(1) {
		transform: translateY(9px) rotate(45deg);
	}
	.mobile-toggle.active span:nth-child(2) {
		opacity: 0;
	}
	.mobile-toggle.active span:nth-child(3) {
		transform: translateY(-9px) rotate(-45deg);
	}
	.mobile-menu {
		display: none;
		position: fixed;
		top: 65px;
		left: 0;
		right: 0;
		background: rgba(10, 10, 11, 0.98);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		padding: 20px;
		flex-direction: column;
		gap: 0;
		z-index: 999;
	}
	.mobile-menu.active {
		display: flex;
	}
	.mobile-menu a {
		display: block;
		padding: 14px 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		color: #a1a1aa;
		font-size: 16px;
		text-decoration: none;
	}
	.mobile-menu a:hover {
		color: #fff;
	}
	@media (max-width: 768px) {
		.header-inner { padding: 12px 16px; }
		.nav { display: none; }
		.mobile-toggle { display: flex; }
	}
</style>

<script>
	const toggle = document.getElementById('nav-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	
	toggle?.addEventListener('click', () => {
		toggle.classList.toggle('active');
		mobileMenu?.classList.toggle('active');
	});
	
	document.querySelectorAll('.mobile-menu a').forEach(link => {
		link.addEventListener('click', () => {
			toggle?.classList.remove('active');
			mobileMenu?.classList.remove('active');
		});
	});
</script>